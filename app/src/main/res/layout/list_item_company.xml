<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/companyLogo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_logo_circle"
        android:contentDescription="@string/company_logo_desc"
        android:padding="12dp"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_logo_repair" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/companyName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="AutoFix Сервис" />

        <TextView
            android:id="@+id/companyAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            tools:text="ул. Партизанска 12, Скопје" />

        <TextView
            android:id="@+id/companyPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            tools:text="+389 70 123 456" />

        <TextView
            android:id="@+id/companyWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/primary"
            android:textSize="14sp"
            tools:text="www.autofix.mk" />

    </LinearLayout>

</LinearLayout>
